<mujoco model="boying">
  <!-- Adapted for mjlab:
       - meshdir changed to "assets" (STL files copied alongside this file)
       - <actuator> block removed (mjlab BuiltinPositionActuatorCfg creates position actuators)
       - <sensor> block replaced with mjlab-expected imu_ang_vel / imu_lin_vel names
       - collision geoms named following the .*_collision pattern used by CollisionCfg
       - foot sites added (FL/FR/RL/RR) at foot-sphere positions in each *_calf body
  -->
  <compiler angle="radian" meshdir="assets" autolimits="true" />

  <default>
    <default class="boying">
      <geom friction="0.4" margin="0.001" condim="1"/>
      <joint axis="0 1 0" damping="0.1" armature="0.01" frictionloss="1.6"/>
      <default class="abduction">
        <joint axis="1 0 0" range="-0.69813 0.69813"/>
      </default>
      <default class="hip">
        <joint range="-0.175 4.712"/>
      </default>
      <default class="knee">
        <joint range="-2.7478 -0.9269"/>
      </default>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom group="3"/>
      </default>
    </default>
  </default>

  <asset>
    <mesh name="base"    content_type="model/stl" file="base.STL"/>
    <mesh name="head"    content_type="model/stl" file="head.STL"/>
    <mesh name="FL_hip"  content_type="model/stl" file="FL_hip.STL"/>
